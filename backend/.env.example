PORT=4000
NODE_ENV=development

MONGODB_URI=mongodb://127.0.0.1:27017/cozyfoam

# Clerk (Backend for customer auth)
CLERK_SECRET_KEY=sk_test_...

# Razorpay
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# Cloudinary
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# Admin auth (non-Clerk). Login requests go to the API URL your frontend uses (see frontend/.env VITE_API_BASE_URL).
# For local dev, frontend should use http://localhost:4000/api so these values apply.
ADMIN_EMAIL=admin@cozyfoam.com
ADMIN_PASSWORD=change-me
ADMIN_JWT_SECRET=replace-with-long-random-secret

