# Backend API base (must include `/api` suffix — see frontend/src/api/client.ts)
#
# Local admin login uses credentials from `backend/.env` (ADMIN_EMAIL / ADMIN_PASSWORD):
#   VITE_API_BASE_URL=http://localhost:4000/api
#
# Deployed site uses your hosted API (set the same ADMIN_* vars on the host, e.g. Render):
#   VITE_API_BASE_URL=https://your-api.example.com/api

VITE_API_BASE_URL=http://localhost:4000/api

# Optional: homepage WhatsApp float (digits only, country code first, no + or spaces)
# VITE_WHATSAPP_PHONE=911234567890
# VITE_WHATSAPP_MESSAGE=Hi, I would like help with Uniik outdoor furniture.
